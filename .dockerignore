# Canonical .dockerignore for a Forge frontend repo (mirrors SRSC #1314).
# Keeps the build context lean; no host state / secrets / deps leak into the image.

# Version control / CI
.git
.github

# Installed deps + build caches (the image installs + builds its own)
**/node_modules
**/.next
**/.turbo
**/dist
**/*.tsbuildinfo
coverage

# Secrets / local env
.env
.env.*
*.pem
.secrets.baseline

# Editor / OS noise
.idea
.vscode
.DS_Store

# Dev-only artifacts not needed in the runtime image
**/__tests__
**/*.test.ts
**/*.test.tsx

# The AI governance layer (poured separately; not part of the runtime image)
.claude
.gemini
AGENTS.md
CLAUDE.md
GEMINI.md

{
  "name": "calliope",
  "version": "0.1.0",
  "private": true,
  "description": "The Notes & Prose Muse's MCP body service",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22.13"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "esbuild"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css}\"",
    "gate": "bun run format:check && turbo run lint typecheck test build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "overrides": {
    "kysely": ">=0.28.12",
    "fast-uri": "4.1.1",
    "brace-expansion": "5.0.7",
    "@hono/node-server": ">=2.0.10"
  }
}

{
  "name": "@forge/calliope",
  "version": "0.1.0",
  "description": "Calliope — the Notes & Prose Muse's wire: the MCP body service (read_body/write_body/append_section/edit_section) over the section body model (hasPart/text/order_key). The editor surface lives in @forge/aglaia.",
  "license": "Apache-2.0",
  "author": "Rob Fischer",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22.13"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "calliope-mcp": "./src/mcp/main.ts",
    "calliope-mcp-http": "./src/mcp/http.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "start": "bun run src/mcp/main.ts",
    "start:http": "bun run src/mcp/http.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.22.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.2.6"
  },
  "trustedDependencies": [
    "esbuild"
  ],
  "overrides": {
    "kysely": ">=0.28.12"
  }
}

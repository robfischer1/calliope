{
  "name": "@forge/calliope",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "calliope-mcp": "./src/mcp/main.ts",
    "calliope-mcp-http": "./src/mcp/http.ts"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "bun run --watch src/mcp/http.ts",
    "build": "bun build src/mcp/http.ts --target=bun --outfile dist/server.js",
    "start": "bun run src/mcp/main.ts",
    "start:http": "bun run src/mcp/http.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.22.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
